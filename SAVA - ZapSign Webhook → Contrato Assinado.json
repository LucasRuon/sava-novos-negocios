    {
      "parameters": {
        "jsCode": "const d = $('Extrair Dados do Payload').item.json;\nconst dataFormatada = new Date(d.data_assinatura)\n  .toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n\nconst mensagem = [\n  '✅ *Contrato Assinado!*',\n  '',\n  `📄 *Documento:* ${d.doc_nome}`,\n  `👤 *Assinado por:* ${d.signatario_nome}`,\n  `📧 *E-mail:* ${d.signatario_email}`,\n  `🕐 *Data/Hora:* ${dataFormatada}`,\n  `✍️ *Signatários:* ${d.assinados}/${d.total_signatarios} assinaram`,\n  '',\n  `📎 *PDF Assinado:* ${d.signed_file}`\n].join('\\n');\n\nreturn [{ json: { mensagem, dados: d } }];"
      },
