    {
      "parameters": {
        "jsCode": "// Payload real ZapSign:\n// body.event_type = 'doc_signed' dispara a CADA assinatura individual\n// body.status = 'signed' SOMENTE quando TODOS os signatários assinaram\n// body.status = 'pending' quando ainda há signatários pendentes\n// body.token = token do documento (= zapsign_token na planilha)\n// body.signer_who_signed = quem acabou de assinar neste disparo\n// body.signed_file = URL do PDF assinado (disponível mesmo em 'pending')\n\nconst body = $input.first().json.body;\nconst signer = body.signer_who_signed || {};\n\nreturn [{\n  json: {\n    event_type: body.event_type || '',\n    doc_status: body.status || '',\n    zapsign_token: body.token || '',\n    doc_nome: body.name || '',\n    signed_file: body.signed_file || '',\n    signatario_nome: signer.name || '',\n    signatario_email: signer.email || '',\n    signatario_telefone: (signer.phone_country || '') + (signer.phone_number || ''),\n    data_assinatura: signer.signed_at || new Date().toISOString(),\n    total_signatarios: (body.signers || []).length,\n    assinados: (body.signers || []).filter(s => s.status === 'signed').length\n  }\n}];"
      },
      "id": "15f9dab8-7490-42ee-a313-8371615926ac",
